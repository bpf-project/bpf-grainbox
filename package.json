{
  "name": "@bpf-project/grainbox",
  "private": true,
  "version": "0.1.0",
  "description": "Grainbox product layer and integrations",
  "packageManager": "npm@10",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build:transcript-rendering": "npm -w packages/transcript-rendering run build",
    "pretest": "npm run build:transcript-rendering",
    "test": "vitest run && npm -w apps/web run test",
    "pretypecheck": "npm run build:transcript-rendering",
    "typecheck": "tsc --noEmit && npm -w apps/web run typecheck",
    "build:web": "npm -w apps/web run build",
    "check:feature-matrix": "node scripts/check-feature-matrix.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "obug": "^2.1.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.10"
  }
}
